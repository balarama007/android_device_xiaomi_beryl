# Android fstab file.
# The filesystem that contains the filesystem checker binary (typically /system) cannot
# specify MF_CHECK, and must come before any filesystems that do specify MF_CHECK

# mount point          fstype  device                                        device2              flags

# Special logical partitions (custom label)
/mi_ext                ext4    mi_ext                                                             flags=display="Mi EXT";logical;slotselect
/mi_ext                erofs   mi_ext                                                             flags=display="Mi EXT";logical;slotselect
/system_ext            ext4    system_ext                                                         flags=display="System EXT";logical;slotselect
/system_ext            erofs   system_ext                                                         flags=display="System EXT";logical;slotselect
/vendor_dlkm           ext4    vendor_dlkm                                                        flags=display="Vendor DLKM";logical;slotselect
/vendor_dlkm           erofs   vendor_dlkm                                                        flags=display="Vendor DLKM";logical;slotselect
/system_dlkm           ext4    system_dlkm                                                        flags=display="System DLKM";logical;slotselect
/system_dlkm           erofs   system_dlkm                                                        flags=display="System DLKM";logical;slotselect

# Boot
/boot                  emmc    /dev/block/bootdevice/by-name/boot                                 flags=display="Boot";backup=1;slotselect;flashimg=1
/init_boot             emmc    /dev/block/bootdevice/by-name/init_boot                            flags=display="Init-Boot";slotselect;backup=1;flashimg=1
/vendor_boot           emmc    /dev/block/bootdevice/by-name/vendor_boot                          flags=display="Vendor-Boot";slotselect;backup=1;flashimg=1
/recovery              emmc    /dev/block/bootdevice/by-name/recovery                             flags=display="Recovery";slotselect;backup=1;flashimg=1

# Data
/metadata              f2fs    /dev/block/bootdevice/by-name/metadata                             flags=display="Metadata";backup=1;fsflags="noatime,nosuid,nodev,discard,data_flush wait";wrappedkey
/cache                 ext4    /dev/block/bootdevice/by-name/rescue                               flags=display="Cache";formattable;wipeduringfactoryreset

# UEFI boot logs
/logfs                 vfat    /dev/block/bootdevice/by-name/logfs                                flags=display="LogFS (UEFI)";fsflags="umask=006,uid=1000,gid=1000,utf8"

# VBMeta/AVB partitions
/vbmeta                emmc    /dev/block/bootdevice/by-name/vbmeta                               flags=display="VBMeta";backup=1;slotselect;flashimg=1
/vbmeta_system         emmc    /dev/block/bootdevice/by-name/vbmeta_system                        flags=display="VBMeta System";backup=1;slotselect;flashimg=1

# Persistent Firmware & Properties
/persist               ext4    /dev/block/bootdevice/by-name/persist                              flags=display="Persist";backup=0
/persist_image         emmc    /dev/block/bootdevice/by-name/persist                              flags=display="Persist";flashimg=1;backup=1

# Modem/Firmware partitions
/modem                 vfat    /dev/block/bootdevice/by-name/modem                                flags=display="Modem";slotselect;fsflags="ro,shortname=lower,uid=1000,gid=1000,dmask=227,fmask=337,context=u:object_r:firmware_file:s0 wait"
/modem_image           emmc    /dev/block/bootdevice/by-name/modem                                flags=display="Modem";slotselect;backup=1;flashimg=1
/dsp                   ext4    /dev/block/bootdevice/by-name/dsp                                  flags=display="DSP";slotselect;fsflags="ro"
/dsp_image             emmc    /dev/block/bootdevice/by-name/dsp                                  flags=display="DSP";slotselect;backup=1
/bluetooth             vfat    /dev/block/bootdevice/by-name/bluetooth                            flags=display="Bluetooth";slotselect;fsflags="ro,shortname=lower,uid=1002,gid=3002,dmask=227,fmask=337,context=u:object_r:bt_firmware_file:s0 wait"
/bluetooth_image       emmc    /dev/block/bootdevice/by-name/bluetooth                            flags=display="Bluetooth";slotselect;backup=1;flashimg=1
/dtbo                  emmc    /dev/block/bootdevice/by-name/dtbo                                 flags=display="DTBO";backup=1;slotselect;flashimg=1

# EFS partitions
/efs1                  emmc    /dev/block/bootdevice/by-name/modemst1                             flags=display="EFS";backup=1;
/efs2                  emmc    /dev/block/bootdevice/by-name/modemst2                             flags=backup=1;subpartitionof=/efs1
/efsc                  emmc    /dev/block/bootdevice/by-name/fsc                                  flags=backup=1;subpartitionof=/efs1
/efsg                  emmc    /dev/block/bootdevice/by-name/fsg                                  flags=backup=1;subpartitionof=/efs1
/qmcs                  emmc    /dev/block/bootdevice/by-name/qmcs                                 flags=backup=1;subpartitionof=/efs1
/mbnconfig             emmc    /dev/block/bootdevice/by-name/mbnconfig                            flags=backup=1;subpartitionof=/efs1
/connsec               emmc    /dev/block/bootdevice/by-name/connsec                              flags=backup=1;subpartitionof=/efs1
/opconfig              emmc    /dev/block/bootdevice/by-name/opconfig                             flags=backup=1;subpartitionof=/efs1

# DRM / Device key partitions
/ssd                   emmc    /dev/block/bootdevice/by-name/ssd                                  flags=display="DRM/Security";backup=1
/secdata               emmc    /dev/block/bootdevice/by-name/secdata                              flags=backup=1;subpartitionof=/ssd
/storsec               emmc    /dev/block/bootdevice/by-name/storsec                              flags=backup=1;subpartitionof=/ssd
/spunvm                emmc    /dev/block/bootdevice/by-name/spunvm                               flags=backup=1;subpartitionof=/ssd
/keystore              emmc    /dev/block/bootdevice/by-name/keystore                             flags=backup=1;subpartitionof=/ssd
/opcust                emmc    /dev/block/bootdevice/by-name/opcust                               flags=backup=1;subpartitionof=/ssd

# Bootloader/TrustZone/Hypervisor partitions
/abl                   emmc    /dev/block/bootdevice/by-name/abl                                  flags=display="Bootloader/Trustzone";backup=1;slotselect
/xbl                   emmc    /dev/block/bootdevice/by-name/xbl                                  flags=backup=1;slotselect;subpartitionof=/abl
/xbl_config            emmc    /dev/block/bootdevice/by-name/xbl_config                           flags=backup=1;slotselect;subpartitionof=/abl
/tz                    emmc    /dev/block/bootdevice/by-name/tz                                   flags=backup=1;slotselect;subpartitionof=/abl
/hyp                   emmc    /dev/block/bootdevice/by-name/hyp                                  flags=backup=1;slotselect;subpartitionof=/abl
/uefi                  emmc    /dev/block/bootdevice/by-name/uefi                                 flags=backup=1;slotselect;subpartitionof=/abl
/uefivarstore          emmc    /dev/block/bootdevice/by-name/uefivarstore                         flags=backup=1;slotselect;subpartitionof=/abl
/uefisecapp            emmc    /dev/block/bootdevice/by-name/uefisecapp                           flags=backup=1;slotselect;subpartitionof=/abl
/aop                   emmc    /dev/block/bootdevice/by-name/aop                                  flags=backup=1;slotselect;subpartitionof=/abl
/aop_config            emmc    /dev/block/bootdevice/by-name/aop_config                           flags=backup=1;slotselect;subpartitionof=/abl
/devcfg                emmc    /dev/block/bootdevice/by-name/devcfg                               flags=backup=1;slotselect;subpartitionof=/abl
/qupfw                 emmc    /dev/block/bootdevice/by-name/qupfw                                flags=backup=1;slotselect;subpartitionof=/abl
/featenabler           emmc    /dev/block/bootdevice/by-name/featenabler                          flags=backup=1;slotselect;subpartitionof=/abl
/keymaster             emmc    /dev/block/bootdevice/by-name/keymaster                            flags=backup=1;slotselect;subpartitionof=/abl
/imagefv               emmc    /dev/block/bootdevice/by-name/imagefv                              flags=backup=1;slotselect;subpartitionof=/abl
/cpucp                 emmc    /dev/block/bootdevice/by-name/cpucp                                flags=backup=1;slotselect;subpartitionof=/abl
/shrm                  emmc    /dev/block/bootdevice/by-name/shrm                                 flags=backup=1;slotselect;subpartitionof=/abl
/pvmfw                 emmc    /dev/block/bootdevice/by-name/pvmfw                                flags=backup=1;slotselect;subpartitionof=/abl
/multiimgqti           emmc    /dev/block/bootdevice/by-name/multiimgqti                          flags=backup=1;slotselect;subpartitionof=/abl
/multiimgoem           emmc    /dev/block/bootdevice/by-name/multiimgoem                          flags=backup=1;slotselect;subpartitionof=/abl
/qweslicstore          emmc    /dev/block/bootdevice/by-name/qweslicstore                         flags=backup=1;slotselect;subpartitionof=/abl
/cpucp_dtb             emmc    /dev/block/bootdevice/by-name/cpucp_dtb                            flags=backup=1;slotselect;subpartitionof=/abl
/devinfo               emmc    /dev/block/bootdevice/by-name/devinfo                              flags=backup=1;subpartitionof=/abl
/cdt                   emmc    /dev/block/bootdevice/by-name/cdt                                  flags=backup=1;subpartitionof=/abl
/ddr                   emmc    /dev/block/bootdevice/by-name/ddr                                  flags=backup=1;subpartitionof=/abl
/tzsc                  emmc    /dev/block/bootdevice/by-name/tzsc                                 flags=backup=1;subpartitionof=/abl
/toolsfv               emmc    /dev/block/bootdevice/by-name/toolsfv                              flags=backup=1;subpartitionof=/abl
/charger               emmc    /dev/block/bootdevice/by-name/charger                              flags=backup=1;subpartitionof=/abl
/dpm                   emmc    /dev/block/bootdevice/by-name/dpm                                  flags=backup=1;subpartitionof=/abl
/apdp                  emmc    /dev/block/bootdevice/by-name/apdp                                 flags=backup=1;subpartitionof=/abl
/apdpb                 emmc    /dev/block/bootdevice/by-name/apdpb                                flags=backup=1;subpartitionof=/abl

# Other partitions
/misc                  emmc    /dev/block/bootdevice/by-name/misc
/frp                   emmc    /dev/block/bootdevice/by-name/frp

# Removable storage
/storage       	       auto    /data/media/0                  		                              flags=display="Internal Storage";backup=1;usermrf;fsflags="bind,utf8";removable
/usb_otg               auto    /dev/block/sdg1                            /dev/block/sdg          flags=display="USB-Storage";fsflags="utf8,sync";storage;formattable;removable
